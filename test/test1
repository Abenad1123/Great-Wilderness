<<if Object.keys($player.inventory).length !== 0>>
    <<set _items = Object.keys($player.inventory)>>

    <div id="inventory-grid">
        <<for _i = 0; _i < _items.length; _i++>>
            <<set _id = _items[_i]>>
            <<set _item = setup.item[_id]>>
            <<set _image = "assets/icons/item/" + _item.img>>

            <<if setup.nonStackableItems.some(tag => _item.tag.includes(tag))>>
                <<set _itemUids = Object.keys($player.inventory[_id])>>
                <<run console.log(`Name : ${_item.name} \n Id : ${_id}`)>>
                <<run console.log(Object.keys($player.inventory[_id]))>>
                <<set _loop = _itemUids.length>>
            <<else>>
                <<set _itemUids = []>>
                <<set _loop = 1>>
            <</if>>

            <<for _x = 0; _x < _loop; _x++>>
                <<capture _id, _x>>
                    <div class="inv-cell">
                        <<link [img[_image]]>>
                            <<if _itemUids.length > 0>>
                                <<run $selectedItemUid = _itemUids[_x]>>
                            <<else>>
                                <<run $selectedItemUid = null>>
                            <</if>>
                            <<run $selectedItem = _id>>
                            <<run setup.open_panel("Item_Info_Panel")>>
                        <</link>>
                    </div>
                <</capture>>
            <</for>>

        <</for>>
    </div>

<<else>>
    <div id="inventory-empty">Your inventory is empty.</div>
<</if>>




<<set _id = $selectedItem>>
<<set _uid = $selectedItemUid>>
<<set _item = setup.item[_id]>>

<div id="item-panel">
    <div id="item-panel-img">
        <img @src="'assets/icons/item/' + _item.img">
    </div>

    <div id="item-panel-body">
        <div id="item-panel-header">
            <div id="item-name" class="rarity-<<= _item.rarity>>"><<= _item.name>></div>
            <div id="item-tags">
                <<for _t = 0; _t < _item.tag.length; _t++>>
                    <span class="item-tag"><<= _item.tag[_t]>></span>
                <</for>>
            </div>
        </div>

        <div id="item-desc">
        <<= _item.description>>
        <<if _uid>>
        	<<= _uid>>
        <</if>>
        </div>

        <div id="item-stats">
        	
            <<if _item.stats.power>>
                <div class="stat-entry"><span class="stat-k">Power</span><span class="stat-v"><<= _item.stats.power>></span></div>
            <</if>>
            <<if _item.stats.durability>>
                <div class="stat-entry"><span class="stat-k">Durability</span><span class="stat-v"><<= _item.stats.durability>></span></div>
            <</if>>
            <<if _item.stats.value>>
                <div class="stat-entry"><span class="stat-k">Value</span><span class="stat-v"><<= _item.stats.value>> g</span></div>
            <</if>>
            <<if _item.stats.weight>>
                <div class="stat-entry"><span class="stat-k">Weight</span><span class="stat-v"><<= _item.stats.weight>> kg</span></div>
            <</if>>
        </div>
    </div>
</div>